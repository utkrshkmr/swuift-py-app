# Python caches / bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/
dist_arm64/
dist_x86_64/
*.zip

# Virtual environments
.venv/
venv/
env/

# PyInstaller workspace
*.manifest
*.spec.bak

# OS / editor clutter
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Runtime data (large) — each user supplies their own copy.
# The extraction scripts inside eaton_legacy_data/ are tracked; the
# legacy .mat bundle they consume is not.  The full sample dataset
# lives on GitHub Releases (see SAMPLE_DATA.md).
eaton_legacy_data/*.mat
eaton_legacy_data/.DS_Store
eaton_sample_data/
eaton_sample_csv/
extracted_csv/
outputs/

# Inno Setup output
Output/

# CI artifact staging
artifacts/
